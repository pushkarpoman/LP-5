#include <iostream>
#include <omp.h>

using namespace std;

int main() {

    int arr[5] = {12, 10, 25, 15, 30};

    int sum = 0;
    int minVal = arr[0];
    int maxVal = arr[0];

    #pragma omp parallel for reduction(+:sum) reduction(min:minVal) reduction(max:maxVal)
    for(int i = 0; i < 5; i++) {

        sum += arr[i];

        if(arr[i] < minVal)
            minVal = arr[i];

        if(arr[i] > maxVal)
            maxVal = arr[i];
    }

    float avg = sum / 5.0;

    cout << "Min = " << minVal << endl;
    cout << "Max = " << maxVal << endl;
    cout << "Sum = " << sum << endl;
    cout << "Average = " << avg << endl;

    return 0;
}
