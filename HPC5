#include <iostream>
#include <omp.h>

using namespace std;

#define N 6

int main() {

    // Training data
    float X[N] = {1, 2, 3, 4, 5, 6};

    float Y[N] = {2, 9, 6, 3, 10, 12};

    // Initial model weight
    float W = 0.2;

    float learning_rate = 0.01;

    float gradient = 0;

    // Parallel computation
    #pragma omp parallel for reduction(+:gradient)

    for (int i = 0; i < N; i++) {

        float prediction = W * X[i];

        float error = prediction - Y[i];

        gradient += error * X[i];
    }

    // Weight update
    W = W - learning_rate * (gradient / N);

    cout << "Updated Weight: " << W << endl;

    return 0;
}
